NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:123@localhost:5432/calc_hub
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000
# За Caddy с TLS фронт на https — API тоже только https://api…, иначе браузер блокирует mixed content.
CORS_ORIGINS=https://numlix.local,https://panel.numlix.local,https://admin.numlix.local
NUMLIX_API_URL=https://api.numlix.local
# Общая сессия panel + apex numlix.local → api.numlix.local (fetch с другого хоста): нужен Domain и часто SameSite=none.
COOKIE_DOMAIN=.numlix.local
# auto: Secure если X-Forwarded-Proto=https (Caddy); false — только http://localhost:3001
COOKIE_SECURE=auto
# none + Secure — куки на refresh/access уходят с https://numlix.local на https://api… (иначе браузер режет как cross-site).
COOKIE_SAMESITE=none
COOKIE_ACCESS_NAME=numlix_access_token
COOKIE_REFRESH_NAME=numlix_refresh_token
ADMIN_EMAIL=admin@calc-hub.local
ADMIN_PASSWORD=Admin12345!
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ROBOKASSA_PASSWORD_1=
ROBOKASSA_PASSWORD_2=
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=calc-hub
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
